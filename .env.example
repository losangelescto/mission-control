# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mission_control
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mission_control

# ─── API ────────────────────────────────────────────────────
API_URL=http://localhost:8000
APP_ENV=local
APP_VERSION=dev
LOG_LEVEL=INFO

# Comma-separated origins. Never use * in production.
CORS_ORIGINS=http://localhost:3000

# Rate limiting (slowapi format: "<count>/<period>")
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_RECOMMENDATION=10/minute

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── LLM ────────────────────────────────────────────────────
# `mock` (default, deterministic, no network) or `anthropic`
LLM_PROVIDER=mock
LLM_API_KEY=
# Model id — override for Claude variants, e.g. claude-opus-4-6
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1500
# Low temperature for operational recommendations
LLM_TEMPERATURE=0.3
# How long a recommendation stays fresh before it may be regenerated.
# Context-hash matching is also required — any task/update/sub-task/
# obstacle change busts the cache regardless of this value.
RECOMMENDATION_CACHE_SECONDS=300

# ─── Transcription (Week 3 · Day 1) ─────────────────────────
# `mock` (default, no network) or `whisper` (OpenAI Whisper API)
TRANSCRIPTION_PROVIDER=mock
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
# Per-file safety cap. Sources longer than this are rejected up front.
MAX_AUDIO_DURATION_SECONDS=7200

# ─── Source processing (Week 3 · Day 1) ─────────────────────
# Per-batch timeout for chunked PDF page extraction.
PDF_BATCH_TIMEOUT_SECONDS=60
# Hard ceiling on the entire processing run for a single document.
PROCESSING_OVERALL_TIMEOUT_SECONDS=1800

# ─── Task extraction (Week 3 · Day 2) ───────────────────────
# When true, source ingestion auto-extracts task candidates after text
# is in place. Canon documents are always skipped.
AUTO_EXTRACT_TASKS=true
# Candidates with confidence below this are tagged so the UI can hide
# them unless the operator opts in (default: 0.6).
EXTRACTION_CONFIDENCE_THRESHOLD=0.6
# Long transcripts are split into windows of this many minutes for
# extraction; 0 disables windowing.
EXTRACTION_WINDOW_MINUTES=10

# ─── Azure ──────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=

# ─── Feature flags ──────────────────────────────────────────
USE_FIXTURE_MAILBOX=true
USE_GRAPH_MAILBOX=false
ENABLE_LIVE_CANON_SYNC=false
ENABLE_TEAMS_CALL_CONNECTOR=true
ENABLE_OUTBOUND_ROLLUPS=false
