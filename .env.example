# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mission_control
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mission_control

# ─── API ────────────────────────────────────────────────────
API_URL=http://localhost:8000
APP_ENV=local
CORS_ORIGINS=http://localhost:3000

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── LLM ────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_API_KEY=

# ─── Azure ──────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=

# ─── Feature flags ──────────────────────────────────────────
USE_FIXTURE_MAILBOX=true
USE_GRAPH_MAILBOX=false
ENABLE_LIVE_CANON_SYNC=false
ENABLE_TEAMS_CALL_CONNECTOR=true
ENABLE_OUTBOUND_ROLLUPS=false
