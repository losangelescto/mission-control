# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mission_control
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=mission_control

# ─── API ────────────────────────────────────────────────────
API_URL=http://localhost:8000
APP_ENV=local
APP_VERSION=dev
LOG_LEVEL=INFO

# Comma-separated origins. Never use * in production.
CORS_ORIGINS=http://localhost:3000

# Rate limiting (slowapi format: "<count>/<period>")
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_RECOMMENDATION=10/minute

# ─── Web ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── LLM ────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_API_KEY=

# ─── Azure ──────────────────────────────────────────────────
AZURE_KEY_VAULT_URL=

# ─── Feature flags ──────────────────────────────────────────
USE_FIXTURE_MAILBOX=true
USE_GRAPH_MAILBOX=false
ENABLE_LIVE_CANON_SYNC=false
ENABLE_TEAMS_CALL_CONNECTOR=true
ENABLE_OUTBOUND_ROLLUPS=false
