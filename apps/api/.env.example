APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mission_control
SOURCES_UPLOAD_DIR=data/uploads

# --- Phase 1 POC feature flags (see docs/runbook.md) ---
USE_FIXTURE_MAILBOX=true
USE_GRAPH_MAILBOX=false
ENABLE_LIVE_CANON_SYNC=false
ENABLE_TEAMS_CALL_CONNECTOR=true
ENABLE_OUTBOUND_ROLLUPS=false

# Optional Microsoft Graph (stub only; also set USE_GRAPH_MAILBOX=true)
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
